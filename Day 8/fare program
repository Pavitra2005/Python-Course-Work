hr,min = list(map(int,input("Enter the time :").split(':')))
fare=0
price=350

if 0<=hr<=23 and 0<=min<=59:

    if 8<=hr<=16:
        fare=40
    elif 17<=hr<=23:
        fare=100
    elif 0<=hr<=7:
        fare=150
    print("Total fare:",fare+price)
else:
    print("invalid time")
